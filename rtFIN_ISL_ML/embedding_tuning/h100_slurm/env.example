# Copy this file to env.sh and edit for your H100 project.

# Project root that contains train_embedding.py.
export PROJECT_DIR="/mnt/cepheid/users/hsypfsv/rtFIN_ISL_ML/embedding_tuning"
export TRAIN_SCRIPT="$PROJECT_DIR/train_embedding.py"

# Hugging Face dataset source. The job downloads these files automatically.
export HF_DATASET_REPO="hyunseop/Nemotron-Personas-Korea-Embedding-ContrastiveLearning"
export HF_BGE_FILE="train_bge_m3.jsonl"
export HF_QWEN_FILE="train_qwen3.jsonl"
export DATA_SOURCE_DIR="${SCRIPT_DIR}/source_data"
export BGE_TRAIN_FILE="$DATA_SOURCE_DIR/train_bge_m3.jsonl"
export QWEN_TRAIN_FILE="$DATA_SOURCE_DIR/train_qwen3.jsonl"

# Leave empty to run directly on the node.
# Set to a built image tag to run in Docker.
export DOCKER_IMAGE=""

# Slurm/cluster defaults. These can also be overridden at sbatch time.
export MODEL_SUITE="both"          # both | bge | qwen
export GPU_TYPE="h100"
export GPU_COUNT="${SLURM_GPUS_ON_NODE:-2}"
export CPUS_PER_TASK="${SLURM_CPUS_PER_TASK:-32}"

# W&B
export WANDB_PROJECT="rtfin_embedding_h100"

# Bootstrap behavior.
export INSTALL_AXOLOTL="0"
export AXOLOTL_PACKAGE="axolotl"

# BGE profile
export BGE_MODEL="dragonkue/BGE-m3-ko"
export BGE_BATCH_SIZE="16"
export BGE_GRAD_ACCUM="2"
export BGE_EPOCHS="3"
export BGE_LR="2e-5"
export BGE_EVAL_SAMPLES="2000"
export BGE_MAX_SEQ_LENGTH="512"

# Qwen profile. Start conservative, then increase sequence length/steps on H100.
export QWEN_MODEL="Qwen/Qwen3-Embedding-4B"
export QWEN_BATCH_SIZE="1"
export QWEN_GRAD_ACCUM="8"
export QWEN_EPOCHS="1"
export QWEN_MAX_STEPS="1500"       # -1 means use QWEN_EPOCHS over the full train split
export QWEN_LR="1e-5"
export QWEN_EVAL_SAMPLES="1000"
export QWEN_MAX_SEQ_LENGTH="512"

# Memory behavior
export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"
export TOKENIZERS_PARALLELISM="false"
export NCCL_DEBUG="WARN"
